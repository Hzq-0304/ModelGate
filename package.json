{
  "name": "modelgate",
  "version": "0.1.1",
  "description": "Local OpenAI-compatible model request router and provider hot-switch gateway.",
  "type": "module",
  "private": false,
  "bin": {
    "modelgate": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "dev:desktop": "npm --prefix desktop run tauri -- dev",
    "build:desktop": "npm --prefix desktop run tauri -- build",
    "build:desktop:nsis": "npm --prefix desktop run tauri -- build --bundles nsis",
    "build:desktop:debug": "npm --prefix desktop run tauri -- build --debug",
    "dev:desktop-ui": "npm --prefix desktop run dev",
    "build:desktop-ui": "npm --prefix desktop run build",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "release:prepare": "npm run typecheck && npm run build && npm run build:desktop-ui && npm run build:desktop",
    "release:local": "npm run release:prepare && node scripts/prepare-release.mjs"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
