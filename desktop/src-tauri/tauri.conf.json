{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ModelGate",
  "version": "0.1.4",
  "identifier": "com.modelgate.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ModelGate",
        "width": 980,
        "height": 680,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
